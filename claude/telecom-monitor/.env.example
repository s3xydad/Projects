# ── Reddit (free — create app at https://www.reddit.com/prefs/apps) ──────────
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=TelecomMonitor/1.0 by u/your_username

# ── Twitter/X (requires Basic API tier — https://developer.twitter.com) ───────
# Free tier is severely limited; Basic tier (~$100/mo) is the minimum useful tier.
TWITTER_BEARER_TOKEN=your_bearer_token
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_token_secret

# ── Facebook (requires approved app + page access tokens) ─────────────────────
# Graph API v18+ only exposes public Page posts with a valid Page Access Token.
# Request "pages_read_engagement" and "pages_read_user_content" permissions.
FACEBOOK_ACCESS_TOKEN=your_page_access_token

# ── Storage ───────────────────────────────────────────────────────────────────
DB_PATH=telecom_monitor.db

# ── Pipeline settings ─────────────────────────────────────────────────────────
LOOKBACK_DAYS=730
REQUEST_DELAY_SECONDS=2.0
MAX_RETRIES=3
